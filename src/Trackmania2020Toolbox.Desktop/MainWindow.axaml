<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Trackmania2020Toolbox.Desktop"
        xmlns:core="clr-namespace:Trackmania2020Toolbox;assembly=Trackmania2020Toolbox.Core"
        x:Class="Trackmania2020Toolbox.Desktop.MainWindow"
        x:CompileBindings="True"
        Title="Trackmania 2020 Toolbox"
        Width="900" Height="700">
    <Grid RowDefinitions="*, 200">
        <!-- Main Content -->
        <TabControl Grid.Row="0" Name="MainTabControl">
            <!-- Browser Tab -->
            <TabItem Header="Browser" Name="BrowserTab">
                <Grid RowDefinitions="Auto, *, Auto" Margin="10">
                    <!-- Navigation Bar -->
                    <Grid Grid.Row="0" RowDefinitions="Auto, Auto" Margin="0,0,0,10">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
                            <Button Content="Up" Width="40" Name="BrowserUpBtn"/>
                            <TextBox Grid.Column="1" Margin="5,0" Name="BrowserPathDisplay" IsReadOnly="True" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Refresh" Name="BrowserRefreshBtn"/>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,5,0,0">
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" Name="BrowserSearchInput" Watermark="Search maps and folders..."/>
                            <TextBlock Text="Sort:" VerticalAlignment="Center" Margin="10,0,5,0" Grid.Column="2"/>
                            <ComboBox Grid.Column="3" Name="BrowserSortCombo" SelectedIndex="0">
                                <ComboBoxItem>Name (A-Z)</ComboBoxItem>
                                <ComboBoxItem>Name (Z-A)</ComboBoxItem>
                            </ComboBox>
                        </Grid>
                    </Grid>

                    <!-- File List -->
                    <ListBox Grid.Row="1" Name="BrowserList">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="core:BrowserItem">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding Icon}" Width="20"/>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Play" Width="80" Name="BrowserPlayBtn"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Downloads Tab -->
            <TabItem Header="Downloads">
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="15">
                        <TextBlock Text="Download Maps" FontSize="20" FontWeight="Bold"/>

                        <HeaderedContentControl Header="Weekly Shorts">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Weeks (e.g., 68, 70-72) or 'latest':"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Name="WeeklyShortsInput" Text="latest"/>
                                    <Button Grid.Column="1" Content="Download" Margin="5,0,0,0" Name="WeeklyShortsBtn"/>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="Weekly Grands">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Weeks (e.g., 65) or 'latest':"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Name="WeeklyGrandsInput" Text="latest"/>
                                    <Button Grid.Column="1" Content="Download" Margin="5,0,0,0" Name="WeeklyGrandsBtn"/>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="Seasonal">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Campaign name (e.g., Winter 2024) or 'latest':"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Name="SeasonalInput" Text="latest"/>
                                    <Button Grid.Column="1" Content="Download" Margin="5,0,0,0" Name="SeasonalBtn"/>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="Track of the Day">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Date (YYYY-MM, YYYY-MM-DD, or range) or 'latest':"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Name="ToTDInput" Text="latest"/>
                                    <Button Grid.Column="1" Content="Download" Margin="5,0,0,0" Name="ToTDBtn"/>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>

                        <HeaderedContentControl Header="Club Campaign">
                            <StackPanel Spacing="5">
                                <TextBlock Text="Search term or ID (clubId/campaignId):"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Name="ClubInput"/>
                                    <Button Grid.Column="1" Content="Download" Margin="5,0,0,0" Name="ClubBtn"/>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Exchange Tab -->
            <TabItem Header="Exchange">
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="15">
                        <TextBlock Text="Trackmania Exchange (TMX)" FontSize="20" FontWeight="Bold"/>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Download maps by ID or URL (comma-separated):"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Name="TmxInput"/>
                                <Button Grid.Column="1" Content="Download" Margin="5,0,0,0" Name="TmxDownloadBtn"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Download Map Pack by ID or URL:"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Name="TmxPackInput"/>
                                <Button Grid.Column="1" Content="Download Pack" Margin="5,0,0,0" Name="TmxPackBtn"/>
                            </Grid>
                        </StackPanel>

                        <HeaderedContentControl Header="Search TMX">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*, *, Auto">
                                    <TextBox Name="TmxSearchNameInput" Watermark="Track Name"/>
                                    <TextBox Grid.Column="1" Name="TmxSearchAuthorInput" Watermark="Author" Margin="5,0"/>
                                    <Button Grid.Column="2" Content="Search" Name="TmxSearchBtn"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">
                                    <TextBlock Text="Sort:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox Grid.Column="1" Name="TmxSortCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                                        <ComboBoxItem>Name</ComboBoxItem>
                                        <ComboBoxItem>Author</ComboBoxItem>
                                        <ComboBoxItem>Awards</ComboBoxItem>
                                        <ComboBoxItem>Downloads</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Grid.Column="2" Text="Order:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                                    <ComboBox Grid.Column="3" Name="TmxOrderCombo" SelectedIndex="0" HorizontalAlignment="Stretch">
                                        <ComboBoxItem>Ascending</ComboBoxItem>
                                        <ComboBoxItem>Descending</ComboBoxItem>
                                    </ComboBox>
                                    <Button Grid.Column="4" Content="Random Map" Margin="10,0,0,0" Name="TmxRandomBtn"/>
                                </Grid>
                            </StackPanel>
                        </HeaderedContentControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Fixer Tab -->
            <TabItem Header="Fixer">
                <StackPanel Margin="20" Spacing="15">
                    <TextBlock Text="Batch Fix Maps" FontSize="20" FontWeight="Bold"/>
                    <CheckBox Name="UpdateTitleCheck" Content="Update TitleId (OrbitalDev@falguiere -> TMStadium)" IsChecked="True"/>
                    <CheckBox Name="ConvertMapTypeCheck" Content="Convert MapType (TM_Platform -> TM_Race)" IsChecked="True"/>
                    <CheckBox Name="DryRunCheck" Content="Dry Run (Preview changes)"/>
                    <CheckBox Name="ForceOverwriteCheck" Content="Force Overwrite"/>

                    <TextBlock Text="Target Folder:"/>
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox Name="FixerFolderInput"/>
                        <Button Grid.Column="1" Content="Browse" Margin="5,0,0,0" Name="BrowseFixerBtn"/>
                    </Grid>

                    <Button Content="Run Fixer" HorizontalAlignment="Stretch" Name="RunFixerBtn"/>
                </StackPanel>
            </TabItem>

            <!-- Medals Tab -->
            <TabItem Header="Medals">
                <StackPanel Margin="20" Spacing="15">
                    <TextBlock Text="Export Campaign Medals" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Player ID (GUID):"/>
                    <TextBox Name="PlayerIdInput"/>
                    <TextBlock Text="Campaign Filter (optional):"/>
                    <TextBox Name="MedalsCampaignInput"/>
                    <Button Content="Export to medals.csv" HorizontalAlignment="Stretch" Name="ExportMedalsBtn"/>
                </StackPanel>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="15">
                        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Trackmania.exe Path:"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Name="GamePathInput"/>
                            <Button Grid.Column="1" Content="Browse" Margin="5,0,0,0" Name="BrowseGameBtn"/>
                        </Grid>

                        <TextBlock Text="Browser Folder:"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Name="BrowserFolderInput"/>
                            <Button Grid.Column="1" Content="Browse" Margin="5,0,0,0" Name="BrowseBrowserFolderBtn"/>
                        </Grid>

                        <Button Content="Save Settings" Name="SaveSettingsBtn"/>

                        <Separator Margin="0,10"/>
                        <TextBlock Text="Options" FontSize="16" FontWeight="SemiBold"/>
                        <CheckBox Name="PlayAfterDownloadCheck" Content="Play map immediately after download/fix"/>
                        <CheckBox Name="DoubleClickToPlayCheck" Content="Double-click to play in Browser" IsChecked="True"/>
                        <CheckBox Name="EnterToPlayCheck" Content="Press Enter to play in Browser" IsChecked="True"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Log Area -->
        <Grid Grid.Row="1" RowDefinitions="Auto, *">
            <TextBlock Grid.Row="0" Text="Log Output" Background="#333" Foreground="White" Padding="5,2"/>
            <TextBox Grid.Row="1" Name="LogOutput" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas,Monospace" Background="Black" Foreground="LightGray"/>
        </Grid>

        <!-- Selection Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Name="SelectionOverlay" Background="#AA000000" IsVisible="False">
            <Border Background="#222" CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" Width="600" Height="500" BorderBrush="#444" BorderThickness="1">
                <Grid RowDefinitions="Auto, *, Auto">
                    <TextBlock Grid.Row="0" Name="SelectionTitle" Text="Select Item" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <ListBox Grid.Row="1" Name="SelectionList" Background="#111">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
                        <Button Content="Cancel" Width="80" Name="SelectionCancelBtn"/>
                        <Button Content="Select" Width="80" Classes="primary" Name="SelectionConfirmBtn"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
